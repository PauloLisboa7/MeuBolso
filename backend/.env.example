# Selecione o cliente de banco: 'pg' para PostgreSQL, 'mysql2' para MySQL, 'sqlite3' para SQLite local
DB_CLIENT=pg

# Opção 1: Use DATABASE_URL para conexão remota (Railway, Heroku, etc)
# Exemplo para PostgreSQL:
DATABASE_URL=postgresql://user:password@containers-us-west-12.railway.app:6543/meubolso

# Opção 2: Use variáveis separadas (se não usar DATABASE_URL)
# DB_HOST=seu-host-db.com
# DB_PORT=5432
# DB_USER=seu_usuario
# DB_PASSWORD=sua_senha
# DB_NAME=meubolso

# Porta do servidor Node
PORT=4000
